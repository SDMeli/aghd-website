# Cloudinary — برای آپلود عکس و فیلم مهمون‌ها
# 1. برو به https://cloudinary.com و یه اکانت رایگان بساز
# 2. از Dashboard: Cloud Name, API Key, API Secret رو بردار
# 3. برو Settings > Upload > Upload presets > Add upload preset
#    - Signing mode: Unsigned
#    - Folder: wedding_aghd
#    - Tags: wedding_aghd
# 4. اسم upload preset رو بذار اینجا:
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=wedding_aghd_unsigned
# برای گالری (لازم نیست public باشه):
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
